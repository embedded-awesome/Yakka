name={{ name }}
upper={{ upper(name) }}
lower={{ lower(at(words, 0)) }}
capitalized={{ capitalize(at(words, 2)) }}
default={{ default(missing.value, "fallback") }}
exists_name={{ exists("name") }}
exists_missing={{ exists("missing.value") }}
exists_in_map={{ existsIn(map, "x") }}
length_words={{ length(words) }}
range={{ join(range(4), ",") }}
sorted={{ join(sort(numbers), ",") }}
unique={{ join(sort(unique(numbers)), ",") }}
first={{ first(numbers) }}
last={{ last(numbers) }}
max={{ max(numbers) }}
min={{ min(numbers) }}
float={{ float(float_text) }}
int={{ int(float_text) }}
round={{ round(float_text, 2) }}
hex={{ hex(255) }}
types={{ isArray(words) }}|{{ isObject(map) }}|{{ isString(name) }}|{{ isNumber(float_text) }}